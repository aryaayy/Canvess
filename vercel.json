{
  "builds": [
    {
      "src": "**/*.php",
      "use": "vercel-php@0.6.2"
    },
    {
      "src": "**/*.{css,js,png,jpg,jpeg,gif,svg,ico,woff,woff2,ttf,eot}",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "handle": "filesystem" },
    {
      "src": "/(.*)",
      "dest": "/index.php"
    }
  ]
}